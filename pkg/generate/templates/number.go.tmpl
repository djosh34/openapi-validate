{{- $name := .Name -}}
{{- if .Nullable -}}
// {{ $name }} is generated.
type {{ $name }} struct {
	Value *json.Number
}
{{- else -}}
// {{ $name }} is generated.
type {{ $name }} json.Number
{{- end }}

var _ json.Unmarshaler = new({{ $name }})

// UnmarshalJSON decodes JSON into the model.
func (n *{{ $name }}) UnmarshalJSON(data []byte) error {
{{- if .EmptyBodyAllowed }}
	if len(data) == 0 {
		return nil
	}

{{- end }}
	trimmed := bytes.TrimSpace(data)
	if bytes.Equal(trimmed, jsonNull) {
{{- if .Nullable }}
		n.Value = nil

		return nil
{{- else }}
		return NullForNotNullableNumberError
{{- end }}
	}

	if len(trimmed) == 0 || trimmed[0] == '"' {
		return NonNumberForNumberSchemaError
	}

	var value json.Number

	err := json.Unmarshal(trimmed, &value)
	if err != nil {
		return NonNumberForNumberSchemaError
	}

{{ if .Nullable }}
	n.Value = new(value)
{{- else }}
	*n = {{ $name }}(value)
{{- end }}

	return nil
}

// jsonFields returns fields promoted when the model is embedded in allOf.
func (n {{ $name }}) jsonFields() []jsonField {
{{- if .Nullable }}
	return []jsonField{requiredJSONField("Value", n.Value)}
{{- else }}
	return []jsonField{requiredJSONField("{{ $name }}", n)}
{{- end }}
}
