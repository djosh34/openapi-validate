{{- $name := .Name -}}
{{- if .Nullable -}}
type {{ $name }} struct {
	Value *string
}
{{- else -}}
type {{ $name }} string
{{- end }}

var _ json.Unmarshaler = new({{ $name }})

func (s *{{ $name }}) UnmarshalJSON(data []byte) error {
{{- if .EmptyBodyAllowed }}
	if len(data) == 0 {
		return nil
	}

{{- end }}
	if bytes.Equal(data, jsonNull) {
{{- if .Nullable }}
		s.Value = nil
		return nil
{{- else }}
		return NullForNotNullableStringError
{{- end }}
	}

	var value string
	err := json.Unmarshal(data, &value)
	if err != nil {
		return NonStringForStringSchemaError
	}
{{- if eq .Format "date-time" }}
	_, err = time.Parse(time.RFC3339, value)
	if err != nil {
		return err
	}
{{- end }}

{{- if .Nullable }}
	s.Value = new(value)
{{- else }}
	*s = {{ $name }}(value)
{{- end }}
	return nil
}
