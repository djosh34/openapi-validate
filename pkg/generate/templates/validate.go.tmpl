	"github.com/djosh34/decode_and_validate_generator/pkg/jsonvalue"
	"github.com/djosh34/decode_and_validate_generator/pkg/validation"
)

{{range $operationID, $validation := .Validations}}
var {{$operationID}} = {{template "validation" $validation}}
{{end}}

// validations contains every compiled request-body validation by exact operation ID.
var validations = map[string]*validation.Validation{
	{{range $operationID, $_ := .Validations}}
	{{printf "%q" $operationID}}: {{$operationID}},
	{{end}}
}
{{end}}
